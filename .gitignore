# 前端依赖、构建产物和本地调试目录
front/node_modules/
front/dist/
front/*.tsbuildinfo
front/vite.config.js
front/vite.config.d.ts
front/.vite/
front/.playwright-cli/
front/output/

# Python 虚拟环境、缓存和测试生成目录
.venv/
venv/
**/__pycache__/
**/.pytest_cache/
backend/.pytest-run-*/
*.py[cod]
*.pyo
*.pyd
.coverage
coverage/
htmlcov/

# 应用运行时数据和调试产物
*.log
backend/storage/
output/
tmp/
/storage/

# 本地环境配置，避免数据库密码和其他密钥进入仓库
.env
.env.*
*.env
!*.env.example
!*.env.sample
backend/config/database.env

# Office 临时锁文件和本地工具目录
~$*
.playwright-cli/
.codex/
.agents/
