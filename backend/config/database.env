# MySQL connection settings for the FastAPI backend.
# Copy this file to backend/.env or load it from your runtime environment.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=soft_web
DB_USER=root
DB_PASSWORD=change_me
DB_CHARSET=utf8mb4

# SQLAlchemy-compatible database URL.
# Keep this value in sync with the DB_* fields above.
DATABASE_URL=mysql+pymysql://root:change_me@127.0.0.1:3306/soft_web?charset=utf8mb4

# Connection pool defaults for local research use.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_ECHO_SQL=false
