# MySQL 连接配置模板
# 复制为 backend/config/database.env 后，再根据本机环境填写密码。

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=soft_web
DB_USER=root
DB_PASSWORD=change_me
DB_CHARSET=utf8mb4

# SQLAlchemy 连接地址。程序会根据上面的 DB_* 配置生成实际连接地址，
# 此字段仅作为本地配置参考，修改密码时请同步更新。
DATABASE_URL=mysql+pymysql://root:change_me@127.0.0.1:3306/soft_web?charset=utf8mb4

# 连接池配置
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=1800
DB_ECHO_SQL=false

# 任务结果和后台执行器配置
RESULT_STORAGE_DIR=../storage/results
TASK_EXECUTOR_ENABLED=true
TASK_POLL_INTERVAL_SECONDS=1
